# KPSS Asistan Admin — Server Environment Variables
# Bu dosyayı kopyalayın: cp .env.example .env
# Gerçek değerleri doldurun. .env dosyası asla Git'e commit edilmez.

# ── GitHub ──────────────────────────────────────────────────────────────────
# GitHub Personal Access Token (Settings → Developer settings → PAT)
# GitHub Actions'a da aynı isimle (GITHUB_PAT) secret olarak ekleyin.
GH_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenRouter ───────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Firebase ─────────────────────────────────────────────────────────────────
# serviceAccountKey.json içeriğini tek satır minified JSON olarak girin.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ── Admin Hesabı ─────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=guclu_bir_sifre

# ── Editör Şifre Hash Salt ───────────────────────────────────────────────────
HASH_SALT=kpss_editor_salt_2024

# ── RevenueCat ───────────────────────────────────────────────────────────────
REVENUECAT_SECRET_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REVENUECAT_ENTITLEMENT_ID=premium

# ── Sunucu ───────────────────────────────────────────────────────────────────
PORT=8001
