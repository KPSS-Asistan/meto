rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ═══════════════════════════════════════════════════════════════════════════
    // KPSS 2026 - FIREBASE STORAGE RULES
    // ═══════════════════════════════════════════════════════════════════════════
    
    // Data klasörü - JSON dosyaları (sorular, flashcards, vs.)
    // Herkes okuyabilir, kimse yazamaz (sadece Console'dan yüklenir)
    match /data/{fileName} {
      allow read: if true;
      allow write: if false;
    }
    
    // Kullanıcı profil resimleri (ileride kullanılabilir)
    match /users/{userId}/profile/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Diğer tüm dosyalar - erişim yok
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
